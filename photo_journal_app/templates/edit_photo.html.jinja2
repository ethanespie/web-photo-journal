{# Inline edit panel: lets the user update or cancel edits for a single photo entry. #}
<div id="photo-{{ photo.doc_id }}"
     class="bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700 mb-4">

  <div class="flex justify-center pt-2 px-2">
    <img class="rounded-none transition"
         src="{{ url_for('static', path=photo.file_path) }}"
         alt="" />
  </div>

  <div class="flex">
    <div class="p-5 flex-grow">
      <p class="mb-2 text-sm leading-6 text-gray-600">Uploaded {{ photo.uploaded_at }}</p>

      <!-- Editable fields -->
      <form hx-put="/edit-photo/{{ photo.doc_id }}"
            hx-target="#photo-{{ photo.doc_id }}"
            hx-swap="outerHTML"
            class="space-y-2">
        <textarea name="entry" class="w-full border rounded p-2 text-gray-800 dark:text-gray-200 dark:bg-gray-700" rows="3">{{ photo.entry }}
        </textarea>
        <div class="flex space-x-2 mt-2">
          <button type="submit"
                  class="bg-green-500 text-white px-2 py-1 rounded hover:bg-green-600">Save</button>
          <button type="button"
                  class="bg-gray-400 text-white px-2 py-1 rounded hover:bg-gray-500"
                  hx-get="/get-photo-card/{{ photo.doc_id }}"
                  hx-target="#photo-{{ photo.doc_id }}"
                  hx-swap="outerHTML">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>
