<!-- templates/photo_journal.html.jinja2 -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Photo Journal</title>
    <link href="{{ url_for('static', path='css/styles.css') }}"
          rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="{{ url_for('static', path='src/htmx.min.js') }}"></script>
  </head>
  <body>
    <nav class="w-full bg-blue-200 py-4 shadow sticky top-0 z-50">
      <div class="flex justify-center">
        <h1 class="text-3xl text-black dark:text-white">My Photo Journal</h1>
      </div>
    </nav>

    <div class="grid grid-cols-12 gap-4 mt-4">
      <!-- Column -->
      <div class="col-span-12 md:col-span-4 mx-4">
        <!-- sticky wrapper keeps the add-photo panel visible while scrolling -->
        <div class="sticky-left-panel" style="position:sticky; top:0; z-index:40; align-self:start;">
          <h1 class="text-xl">Add new photo</h1>
          <form id="add-photo-form"
                hx-post="/post-photo"
                hx-target="#photos"
                hx-swap="afterbegin"
                enctype="multipart/form-data">
            <div>
              <label for="photo_upload"
                     class="block my-2 text-sm font-medium text-gray-900 dark:text-white">Photo</label>
              <input type="file"
                     id="photo_upload"
                     name="photo_upload"
                     class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:bg-gray-200 file:text-gray-800 hover:file:bg-gray-300"
                     required />
            </div>
            <div>
              <label for="entry"
                     class="block my-2 text-sm font-medium text-gray-900 dark:text-white">Caption</label>
              <textarea id="entry"
                        name="entry"
                        class="block p-2.5 w-full text-sm text-gray-900 bg-gray-50 rounded-lg border border-gray-300 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
                        placeholder="Write your thoughts here..."
                        required></textarea>
            </div>
            <button type="submit"
                    class="mt-4 rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
              Save entry
            </button>
          </form>
        </div>
      </div>
      <!-- Column -->
      <div class="col-span-12 md:col-span-8 mx-4">
        <div class="flex justify-between">
          <h1 class="text-xl mb-4">My photostream</h1>
        </div>
        <div id="photos">
          {% block photos %}
            {% if invalid_image_file %}
              <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400"
                   role="alert">
                <span class="font-medium">Invalid image file!</span> Upload a valid image file (PNG, JPG, GIF).
              </div>
            {% endif %}
            {% if photos %}
              {% for photo in photos %}
                {% include "photo_card.html.jinja2" %}
              {% endfor %}
              {# Only show the infinite-scroll trigger when there are more photos to load #}
              {% if total_photos is defined and next_skip is defined and total_photos > next_skip %}
                <div id="load-more-trigger"
                     hx-get="/load-more?skip={{ next_skip }}"
                     hx-trigger="revealed once"
                     hx-swap="beforeend"
                     hx-target="#photos"></div>
              {% endif %}
            {% endif %}
          {% endblock %}
        </div>
      </div>
    </div>
    <script>
      // On browser refresh, ensure the page starts at the top.
      (function () {
        window.addEventListener('pageshow', function () {
          const navEntry = performance.getEntriesByType && performance.getEntriesByType('navigation')[0];
          const isReloadByTiming = navEntry && navEntry.type === 'reload';
          const isReloadLegacy = performance.navigation && performance.navigation.type === 1;
          const isReload = isReloadByTiming || isReloadLegacy;
          if (isReload) {
            if ('scrollRestoration' in history) {
              history.scrollRestoration = 'manual';
            }
            window.scrollTo(0, 0);
            setTimeout(function () { window.scrollTo(0, 0); }, 0);
          }
        });
      }());
    </script>
    <script>
      // Keep the left sticky panel exactly below the navbar so it doesn't "jump".
      (function () {
        function updateLeftPanelTop() {
          const nav = document.querySelector('nav');
          const panel = document.querySelector('.sticky-left-panel');
          if (!nav || !panel) return;
          const navHeight = Math.ceil(nav.getBoundingClientRect().height);
          panel.style.top = navHeight + 'px';
        }
        window.addEventListener('load', updateLeftPanelTop);
        window.addEventListener('resize', updateLeftPanelTop);
        // Ensure layout adjustments after HTMX swaps also update the offset
        document.addEventListener('htmx:afterSwap', function () { setTimeout(updateLeftPanelTop, 0); });
      }());
    </script>
    <script>
            document.addEventListener('photo-added', function () {
            const t = document.getElementById('load-more-trigger');
            if (!t) return;
            try {
            const url = new URL(t.getAttribute('hx-get'), window.location.origin);
            const current = parseInt(url.searchParams.get('skip') || '0', 10);
            url.searchParams.set('skip', String(current + 1));
            t.setAttribute('hx-get', url.pathname + '?' + url.searchParams.toString());
            } catch (_) {}
            });
    </script>
    <script>
            document.addEventListener('htmx:afterRequest', function (evt) {
            const ok = evt.detail && evt.detail.xhr && evt.detail.xhr.status >= 200 && evt.detail.xhr.status < 400;
            if (!ok) return;
            const el = evt.detail && evt.detail.elt;
            if (!el || el.id !== 'add-photo-form') return;

            el.reset();
            const file = el.querySelector('input[type=file]');
            if (file) file.value = null;

            // keep your infinite-scroll skip in sync
            window.dispatchEvent(new CustomEvent('photo-added'));
            });
    </script>
  </body>
</html>
