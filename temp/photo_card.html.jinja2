<div id="photo-{{ photo.doc_id }}"
     class="bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700 mb-4">
  <div class="flex justify-center">
    <img class="rounded-t-lg transition"
         src="{{ url_for('static', path=photo.file_path) }}"
         alt="" />
  </div>
  <div class="flex">
    <div class="p-5 flex-grow">
      <p class="mb-2 text-sm leading-6 text-gray-600">Uploaded {{ photo.uploaded_at }}</p>
      <div id="photo-edit-fields-{{ photo.doc_id }}">
        <p class="mb-3 font-normal text-gray-700 dark:text-gray-400 cursor-pointer">{{ photo.entry }}</p>
      </div>
    </div>
    <div class="flex items-center space-x-2 p-4">
      <!-- Edit button -->
      <button class="bg-blue-500 text-white px-2 py-1 rounded hover:bg-blue-600"
              title="Edit photo entry"
              hx-get="/get-edit-photo-form/{{ photo.doc_id }}"
              hx-target="#photo-{{ photo.doc_id }}"
              hx-swap="outerHTML">Edit</button>
      <!-- Delete button -->
      <button class="bg-blue-500 text-white px-2 py-1 rounded hover:bg-red-600"
              title="Delete photo"
              hx-delete="/delete-photo"
              hx-confirm="Are you sure you want to delete this photo?"
              hx-vals='{"photo_id": "{{ photo.doc_id }}"}'
              hx-target="#photo-{{ photo.doc_id }}"
              hx-swap="outerHTML">Delete</button>
    </div>
  </div>
</div>
